{
  "projectType": "cli-tool",
  "projectName": "Kahoot Answer Bot",
  "projectDescription": "A Python CLI bot that automatically answers Kahoot quizzes by looking up quiz answers via the Kahoot API and submitting them in real time.",
  "theme": "palm",
  "primaryColor": "#dedede",
  "lightColor": "#fbde58",
  "darkColor": null,
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "installation", "quickstart"]
          },
          {
            "group": "Usage",
            "pages": ["usage/command-reference", "usage/search-mode", "usage/authentication"]
          },
          {
            "group": "Reference",
            "pages": ["reference/configuration", "reference/caveats", "reference/troubleshooting"]
          }
        ]
      }
